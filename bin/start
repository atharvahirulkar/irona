#!/usr/bin/env bash
# Usage: start irona
set -euo pipefail

if [[ "${1:-}" != "irona" ]]; then
  echo "Usage: start irona"
  exit 1
fi

IRONA_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$IRONA_ROOT"

if [[ ! -d ".venv" ]]; then
  echo "Irona venv missing. Run ./install.sh first."
  exit 1
fi

# shellcheck disable=SC1091
source ".venv/bin/activate"
shift
exec irona start "$@"
